<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<resource xmlns="http://www.wxwidgets.org/wxxrc" version="2.3.0.1">
  <object class="wxPanel" name="PatchInspectorMainPanel">
    <size>300,350</size>
    <style>wxTAB_TRAVERSAL</style>
    <object class="wxBoxSizer" name="bSizer23">
      <orient>wxVERTICAL</orient>
      <object class="sizeritem">
        <flag>wxALL|wxEXPAND</flag>
        <border>12</border>
        <option>1</option>
        <object class="wxBoxSizer" name="bSizer13">
          <orient>wxVERTICAL</orient>
          <object class="sizeritem">
            <flag>wxEXPAND</flag>
            <border>0</border>
            <option>0</option>
            <object class="wxPanel" name="PatchInspectorVertexPanel">
              <style>wxTAB_TRAVERSAL</style>
              <object class="wxBoxSizer" name="bSizer16">
                <orient>wxVERTICAL</orient>
                <object class="sizeritem">
                  <flag>wxBOTTOM</flag>
                  <border>6</border>
                  <option>0</option>
                  <object class="wxStaticText" name="PatchInspectorVertexLabel">
                    <label>Patch Control Vertices</label>
                    <wrap>-1</wrap>
                  </object>
                </object>
                <object class="sizeritem">
                  <flag>wxEXPAND|wxLEFT|wxRIGHT</flag>
                  <border>12</border>
                  <option>0</option>
                  <object class="wxFlexGridSizer" name="fgSizer1">
                    <vgap>0</vgap>
                    <hgap>12</hgap>
                    <growablerows></growablerows>
                    <growablecols>1</growablecols>
                    <rows>2</rows>
                    <cols>2</cols>
                    <object class="sizeritem">
                      <flag>wxALIGN_CENTER_VERTICAL</flag>
                      <border>5</border>
                      <option>0</option>
                      <object class="wxStaticText" name="m_staticText8">
                        <label>Row:</label>
                        <wrap>-1</wrap>
                      </object>
                    </object>
                    <object class="sizeritem">
                      <flag>wxALL|wxEXPAND</flag>
                      <border>5</border>
                      <option>0</option>
                      <object class="wxChoice" name="PatchInspectorControlRow">
                        <selection>0</selection>
                        <content>
                          <item>0</item>
                        </content>
                      </object>
                    </object>
                    <object class="sizeritem">
                      <flag>wxALIGN_CENTER_VERTICAL</flag>
                      <border>0</border>
                      <option>0</option>
                      <object class="wxStaticText" name="m_staticText9">
                        <label>Column:</label>
                        <wrap>-1</wrap>
                      </object>
                    </object>
                    <object class="sizeritem">
                      <flag>wxALL|wxEXPAND</flag>
                      <border>5</border>
                      <option>0</option>
                      <object class="wxChoice" name="PatchInspectorControlColumn">
                        <selection>0</selection>
                        <content>
                          <item>0</item>
                        </content>
                      </object>
                    </object>
                  </object>
                </object>
              </object>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxEXPAND|wxLEFT|wxRIGHT</flag>
            <border>12</border>
            <option>0</option>
            <object class="wxPanel" name="PatchInspectorCoordPanel">
              <style>wxTAB_TRAVERSAL</style>
              <object class="wxBoxSizer" name="bSizer15">
                <orient>wxVERTICAL</orient>
                <object class="sizeritem">
                  <flag>wxBOTTOM|wxTOP</flag>
                  <border>8</border>
                  <option>0</option>
                  <object class="wxStaticText" name="PatchInspectorCoordLabel">
                    <label>Coordinates</label>
                    <wrap>-1</wrap>
                  </object>
                </object>
              </object>
            </object>
          </object>
          <object class="sizeritem">
            <flag>wxEXPAND|wxRIGHT</flag>
            <border>12</border>
            <option>1</option>
            <object class="wxPanel" name="PatchInspectorTessPanel">
              <style>wxTAB_TRAVERSAL</style>
              <object class="wxBoxSizer" name="bSizer20">
                <orient>wxVERTICAL</orient>
                <object class="sizeritem">
                  <flag>wxBOTTOM|wxTOP</flag>
                  <border>6</border>
                  <option>0</option>
                  <object class="wxStaticText" name="PatchInspectorTessLabel">
                    <label>Patch Tesselation</label>
                    <wrap>-1</wrap>
                  </object>
                </object>
                <object class="sizeritem">
                  <flag>wxEXPAND|wxLEFT</flag>
                  <border>12</border>
                  <option>1</option>
                  <object class="wxBoxSizer" name="bSizer14">
                    <orient>wxVERTICAL</orient>
                    <object class="sizeritem">
                      <flag>wxBOTTOM|wxTOP</flag>
                      <border>6</border>
                      <option>0</option>
                      <object class="wxCheckBox" name="PatchInspectorFixedSubdivisions">
                        <label>Fixed Subdivisions</label>
                        <checked>0</checked>
                      </object>
                    </object>
                    <object class="sizeritem">
                      <flag>wxEXPAND|wxTOP</flag>
                      <border>6</border>
                      <option>0</option>
                      <object class="wxFlexGridSizer" name="fgSizer2">
                        <vgap>6</vgap>
                        <hgap>12</hgap>
                        <growablerows></growablerows>
                        <growablecols>1</growablecols>
                        <rows>2</rows>
                        <cols>2</cols>
                        <object class="sizeritem">
                          <flag>wxALIGN_CENTER_VERTICAL|wxALL</flag>
                          <border>0</border>
                          <option>0</option>
                          <object class="wxStaticText" name="PatchInspectorSubdivisionsXLabel">
                            <label>Horizontal:</label>
                            <wrap>-1</wrap>
                          </object>
                        </object>
                        <object class="sizeritem">
                          <flag>wxALIGN_CENTER_VERTICAL</flag>
                          <border>0</border>
                          <option>0</option>
                          <object class="wxSpinCtrl" name="PatchInspectorSubdivisionsX">
                            <style>wxSP_ARROW_KEYS</style>
                            <value>1</value>
                            <min>1</min>
                            <max>16384</max>
                          </object>
                        </object>
                        <object class="sizeritem">
                          <flag>wxALIGN_CENTER_VERTICAL</flag>
                          <border>0</border>
                          <option>0</option>
                          <object class="wxStaticText" name="PatchInspectorSubdivisionsYLabel">
                            <label>Vertical:</label>
                            <wrap>-1</wrap>
                          </object>
                        </object>
                        <object class="sizeritem">
                          <flag></flag>
                          <border>0</border>
                          <option>0</option>
                          <object class="wxSpinCtrl" name="PatchInspectorSubdivisionsY">
                            <style>wxSP_ARROW_KEYS</style>
                            <value>1</value>
                            <min>1</min>
                            <max>16384</max>
                          </object>
                        </object>
                      </object>
                    </object>
                  </object>
                </object>
              </object>
            </object>
          </object>
        </object>
      </object>
    </object>
  </object>
</resource>
